{
  "name": "ai-voice-call-system",
  "version": "1.0.0",
  "description": "Production-ready AI voice call automation system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "npm start --prefix client",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "seed": "node scripts/seed.js"
  },
  "keywords": [
    "ai",
    "voice",
    "twilio",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bull": "^4.11.5",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "mongoose": "^7.6.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.20.1",
    "redis": "^4.6.11",
    "socket.io": "^4.6.0",
    "twilio": "^4.19.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
